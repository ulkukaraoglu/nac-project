

# Postgres

POSTGRES_USER=nac_user
POSTGRES_DB=nac_db
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_PORT=5432

-
# Redis
REDIS_PORT=6379


# FreeRADIUS
RADIUS_AUTH_PORT=1812
RADIUS_ACCOUNTING_PORT=1813
RADIUS_SHARED_SECRET=CHANGE_ME_RADIUS_SECRET
# FreeRADIUS REST -> API /auth
RADIUS_REST_AUTH_URL=http://api:8000/auth
# FreeRADIUS REST -> API /authorize (post-auth)
RADIUS_REST_AUTHORIZE_URL=http://api:8000/authorize
FREERADIUS_DEBUG=0


# API
API_ENV=local
API_PORT=8000


# Auth rate limiting (Redis)
AUTH_RATE_MAX_ATTEMPTS=5
AUTH_RATE_WINDOW_SECONDS=60
AUTH_RATE_BLOCK_SECONDS=300

